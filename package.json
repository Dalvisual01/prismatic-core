{
  "name": "@prismatic/core",
  "version": "0.2.5",
  "description": "Creative coding framework — workspace UI, canvas shell, and controls for generative graphics tools",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup && cp src/style.css dist/style.css",
    "dev": "tsup --watch",
    "dev:playground": "vite",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "p5": "^1.11.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/p5": "^1.7.6",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.5.2",
    "p5": "^1.11.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.8",
    "tsup": "^8.4.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "zustand": "^5.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dalvisual01/prismatic-core.git"
  },
  "license": "MIT"
}
